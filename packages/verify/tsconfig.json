{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noImplicitAny": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": ["@playwright/test", "node"],
    "lib": ["ES2022", "DOM"]
  },
  "include": ["tests/**/*", "lighthouse/**/*", "manifest.ts", "playwright.config.ts"]
}
